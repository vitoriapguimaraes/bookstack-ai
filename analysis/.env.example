# Configurações para carregar dados da API
# Copie este arquivo para .env e preencha os valores

# URL do backend (local ou produção)
BOOKSTACK_API_URL=http://localhost:8000

# Token JWT do Supabase — obtenha em: app → DevTools → localStorage → "sb-...auth-token" → access_token
BOOKSTACK_TOKEN=seu_token_aqui
